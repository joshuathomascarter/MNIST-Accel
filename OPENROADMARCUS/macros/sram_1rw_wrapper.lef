    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 82.0  4.0 84.0  6.0 ; END
  END rdata[20]
  PIN rdata[21]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 86.0  4.0 88.0  6.0 ; END
  END rdata[21]
