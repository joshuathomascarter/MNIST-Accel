    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 62.0  4.0 64.0  6.0 ; END
  END rdata[15]
  PIN rdata[16]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 66.0  4.0 68.0  6.0 ; END
  END rdata[16]
  PIN rdata[17]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 70.0  4.0 72.0  6.0 ; END
  END rdata[17]
  PIN rdata[18]
    DIRECTION OUTPUT ; USE SIGNAL ;
