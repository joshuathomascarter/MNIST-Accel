  END wdata[23]
  PIN wdata[24]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 98.0 290.0 100.0 292.0 ; END
  END wdata[24]
  PIN wdata[25]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 102.0 290.0 104.0 292.0 ; END
  END wdata[25]
  PIN wdata[26]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 106.0 290.0 108.0 292.0 ; END
  END wdata[26]
  PIN wdata[27]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 110.0 290.0 112.0 292.0 ; END
  END wdata[27]
  PIN wdata[28]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 114.0 290.0 116.0 292.0 ; END
  END wdata[28]
  PIN wdata[29]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 118.0 290.0 120.0 292.0 ; END
  END wdata[29]
  PIN wdata[30]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 122.0 290.0 124.0 292.0 ; END
  END wdata[30]
  PIN wdata[31]
    DIRECTION INPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 126.0 290.0 128.0 292.0 ; END
  END wdata[31]
  
  # ── Read data bus [31:0] — abbreviated ──────────────────────────────
  PIN rdata[0]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT  2.0  4.0  4.0  6.0 ; END
  END rdata[0]
  PIN rdata[1]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT  6.0  4.0  8.0  6.0 ; END
  END rdata[1]
  PIN rdata[2]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 10.0  4.0 12.0  6.0 ; END
  END rdata[2]
  PIN rdata[3]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 14.0  4.0 16.0  6.0 ; END
  END rdata[3]
  PIN rdata[4]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 18.0  4.0 20.0  6.0 ; END
  END rdata[4]
  PIN rdata[5]
    DIRECTION OUTPUT ; USE SIGNAL ;
    PORT LAYER met3 ; RECT 22.0  4.0 24.0  6.0 ; END
  END rdata[5]
